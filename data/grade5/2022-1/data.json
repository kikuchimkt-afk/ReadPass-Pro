    "lessonPlan": {
        "focusPoints": [
            {
                "id": "fp1",
                "title": "be動詞（am / is / are）",
                "subtitle": "I am, He is, They are",
                "explanation": "「私は」→ I am、「彼は/彼女は」→ he/she is、「彼らは/私たちは」→ they/we are。主語で使い分けよう！",
                "explanationSimple": "「です」→ am / is / are！ I→am、he/she→is、they/we→are！",
                "sourceQuote": "Sally and Patty are good friends.",
                "sourceLocation": "大問1 Q14",
                "examples": [
                    {
                        "en": "Sally and Patty are good friends.",
                        "ja": "サリーとパティはよい友だちです。",
                        "note": "複数→are",
                        "audio": "audio/ex_fp1_1.mp3"
                    },
                    {
                        "en": "He's from Osaka.",
                        "ja": "かれは大阪出身です。",
                        "note": "He→is",
                        "audio": "audio/ex_fp1_2.mp3"
                    },
                    {
                        "en": "I am a student.",
                        "ja": "わたしは学生です。",
                        "note": "I→am",
                        "audio": "audio/ex_fp1_3.mp3"
                    }
                ],
                "practicePassage": {
                    "en": "My name is Ken. I am twelve years old. My sister Yuki is ten. We are students at Green School. Our teachers are very kind. My best friend Tom is from America. He is in my class.",
                    "ja": "ぼくの名前はケンです。12歳です。妹のゆきは10歳です。わたしたちはグリーン学校の生徒です。先生たちはとてもやさしいです。親友のトムはアメリカ出身です。同じクラスです。",
                    "audioFile": "audio/practice_pp1.mp3"
                },
                "practiceQuestions": [
                    {
                        "q": "「I」の時のbe動詞は？",
                        "a": "am"
                    },
                    {
                        "q": "「he/she」の時のbe動詞は？",
                        "a": "is"
                    },
                    {
                        "q": "「they/we」の時のbe動詞は？",
                        "a": "are"
                    },
                    {
                        "q": "Sally and Pattyのbe動詞は？",
                        "a": "are（複数だから）"
                    }
                ],
                "practiceQuestionsSimple": [
                    {
                        "q": "I __ a student.",
                        "a": "am!"
                    },
                    {
                        "q": "He __ from Osaka.",
                        "a": "is!"
                    },
                    {
                        "q": "They __ friends.",
                        "a": "are!"
                    },
                    {
                        "q": "We __ happy.",
                        "a": "are!"
                    }
                ],
                "highlightPatterns": [
                    "I am",
                    "He is",
                    "She is",
                    "We are",
                    "They are",
                    "is from"
                ],
                "highlightColor": "#4f8cff",
                "highlightLabel": "be動詞",
                "sourceQuoteAudio": "audio/sq_fp1.mp3"
            },
            {
                "id": "fp2",
                "title": "Please don't ～（禁止の表現）",
                "subtitle": "Please Don't...",
                "explanation": "「～しないでください」は Please don't + 動詞の原形 で言うよ！ 図書館で食べないで→Please don't eat in the library.",
                "explanationSimple": "「やめてね」→ Please don't ～！",
                "sourceQuote": "Please don't eat in the library.",
                "sourceLocation": "大問1 Q13",
                "examples": [
                    {
                        "en": "Please don't eat in the library.",
                        "ja": "図書館で食べないでください。",
                        "note": "don't + eat（原形）",
                        "audio": "audio/ex_fp2_1.mp3"
                    },
                    {
                        "en": "Please don't run in the hallway.",
                        "ja": "廊下で走らないでください。",
                        "note": "don't + run（原形）",
                        "audio": "audio/ex_fp2_2.mp3"
