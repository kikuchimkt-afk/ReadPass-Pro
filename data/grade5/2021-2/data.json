    "lessonPlan": {
        "focusPoints": [
            {
                "id": "fp1",
                "title": "じこしょうかいと聞き方",
                "subtitle": "Introducing and Asking",
                "explanation": "「名前は？」「どこ出身？」「いくつ？」を英語で言える・聞けるようになろう！ Whose～?で「だれの？」と聞けるよ。",
                "explanationSimple": "じぶんのことを言ったり、あいてに聞いたりしてみよう！",
                "sourceQuote": "Whose pencil case is this? / He's 65 years old.",
                "sourceLocation": "大問1 Q10, Q15",
                "examples": [
                    {
                        "en": "Whose pencil case is this?",
                        "ja": "これはだれのふでばこ？",
                        "note": "Whose＝だれの",
                        "audio": "audio/ex_fp1_1.mp3"
                    },
                    {
                        "en": "He is 65 years old.",
                        "ja": "かれは65さいです。",
                        "note": "years old＝～さい",
                        "audio": "audio/ex_fp1_2.mp3"
                    },
                    {
                        "en": "Shanti is from India.",
                        "ja": "シャンティはインド出身です。",
                        "note": "be from＝～出身",
                        "audio": "audio/ex_fp1_3.mp3"
                    }
                ],
                "practicePassage": {
                    "en": "Hi! My name is Yuki. I am from Japan. I am ten years old. I like sports. I can swim very fast. My friend Tom is from America. He is eleven years old. He can speak Japanese very well.",
                    "ja": "こんにちは！わたしの名前はゆきです。日本出身です。10さいです。スポーツが好きです。とてもはやく泳げます。友だちのトムはアメリカ出身です。11さいです。日本語がとてもじょうずに話せます。",
                    "audioFile": "audio/practice_pp1.mp3"
                },
                "practiceQuestions": [
                    {
                        "q": "「だれのふでばこ？」は英語で？",
                        "a": "Whose pencil case is this?"
                    },
                    {
                        "q": "「65さいです」は英語で？",
                        "a": "He is 65 years old."
                    },
                    {
                        "q": "「インド出身です」は英語で？",
                        "a": "Shanti is from India."
                    },
                    {
                        "q": "Whoseのあとには何がくる？",
                        "a": "もの（名詞）がくるよ。Whose bag? Whose pen?"
                    }
                ],
                "practiceQuestionsSimple": [
                    {
                        "q": "「だれの？」って英語でなんていう？",
                        "a": "Whose!"
                    },
                    {
                        "q": "「10さい」って英語でなんていう？",
                        "a": "ten years old!"
                    },
                    {
                        "q": "「日本出身」って英語で？",
                        "a": "from Japan!"
                    },
                    {
                        "q": "「Whose bag?」ってどういういみ？",
                        "a": "「だれのかばん？」だよ！"
                    }
                ],
                "highlightPatterns": [
                    "Whose pencil case is this",
                    "He's 65 years old"
                ],
                "highlightColor": "#4f8cff",
                "highlightLabel": "じこしょうかい",
                "sourceQuoteAudio": "audio/sq_fp1.mp3"
